<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="300.0" prefWidth="420.0" styleClass="background" stylesheets="@../styles/login.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ia.ia_base.controllers.ForgotPasswordController">
   <children>
      <Text layoutX="50.0" layoutY="80.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="forgotPassword" text="Forgot password">
         <font>
            <Font size="40.0" />
         </font>
      </Text>

      <TextField fx:id="emailField" layoutX="50.0" layoutY="140.0" promptText="Account email" styleClass="suggestedFields" />

      <Button fx:id="genPassBTN" layoutX="50.0" layoutY="200.0" mnemonicParsing="false" styleClass="BTNs" text="Generate temporary password" />
      <Button fx:id="backToLoginBTN" layoutX="281.0" layoutY="200.0" mnemonicParsing="false" styleClass="BTNs" text="Back to login" />
   </children>
</AnchorPane>
