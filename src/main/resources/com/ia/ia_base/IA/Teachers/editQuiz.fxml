<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="400.0" prefWidth="720.0"
            xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ia.ia_base.controllers.teachers.EditQuizController">
   <children>
      <Text layoutX="38.0" layoutY="69.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Edit Quiz">
         <font>
            <Font size="40.0" />
         </font>
      </Text>

      <Button fx:id="commitChangesBTN" layoutX="38.0" layoutY="345.0" mnemonicParsing="false"
              onAction="#onCommitBTN" text="Commit changes" />
      <Button fx:id="cancelBTN" layoutX="614.0" layoutY="345.0" mnemonicParsing="false"
              onAction="#onCancelBTN" text="Cancel" />

      <TextField fx:id="quizName" layoutX="38.0" layoutY="120.0" prefHeight="64.0" prefWidth="146.0"
                 promptText="Quiz name" />

      <ListView fx:id="questionListView" layoutX="209.0" layoutY="116.0" prefHeight="200.0" prefWidth="200.0" />
      <Text layoutX="265.0" layoutY="106.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Questions">
         <font>
            <Font size="20.0" />
         </font>
      </Text>

      <ListView fx:id="tagsListView" layoutX="466.0" layoutY="116.0" prefHeight="200.0" prefWidth="200.0" />
      <Text layoutX="544.0" layoutY="106.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Tags">
         <font>
            <Font size="20.0" />
         </font>
      </Text>
   </children>
</AnchorPane>
