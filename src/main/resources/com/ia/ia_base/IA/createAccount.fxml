<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="400.0" prefWidth="450.0" styleClass="background" stylesheets="@../styles/login.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ia.ia_base.controllers.RegistrationController">
   <children>
      <Text layoutX="155.0" layoutY="137.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="logsignin" text="Sign Up">
         <font>
            <Font name="Marlett" size="40.0" />
         </font>
      </Text>
      <TextField fx:id="emailField" layoutX="151.0" layoutY="200.0" promptText="Email adress" styleClass="suggestedFields" />
      <Button fx:id="signUpBTN" layoutX="171.0" layoutY="340.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="82.0" styleClass="BTNs" stylesheets="@../styles/login.css" text="Sign Up" textFill="WHITE" />
      <RadioButton fx:id="studentRadio" layoutX="107.0" layoutY="170.0" mnemonicParsing="false" styleClass="suggestedFields" text="I am a Student">
         <toggleGroup>
            <ToggleGroup fx:id="accountTypeGroup" />
         </toggleGroup></RadioButton>
      <RadioButton fx:id="teacherRadio" layoutX="251.0" layoutY="170.0" mnemonicParsing="false" styleClass="suggestedFields" text="I am a Teacher" toggleGroup="$accountTypeGroup" />
      <Text layoutX="118.0" layoutY="79.0" strokeType="OUTSIDE" strokeWidth="0.0" styleClass="factFlux" text="FactFlux">
         <font>
            <Font size="60.0" />
         </font>
      </Text>
      <PasswordField fx:id="passwordField" layoutX="151.0" layoutY="240.0" promptText="Password" styleClass="suggestedFields" />
      <PasswordField fx:id="repeatPasswordField" layoutX="151.0" layoutY="280.0" promptText="Repeat Password" styleClass="suggestedFields" />
      <Button fx:id="backToLoginBTN" layoutX="301.0" layoutY="340.0" mnemonicParsing="false" prefHeight="25.0" prefWidth="107.0" styleClass="BTNs" stylesheets="@../styles/login.css" text="Back to Log in" textFill="WHITE" />
   </children>
</AnchorPane>
